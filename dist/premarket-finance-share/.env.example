# 盘前财经资讯研判智能体 - 环境变量示例
# 复制为 .env 后填入实际值

# ============ 微信推送 ============
# 全局默认 pushplus token（不推荐，建议每个用户单独配 token）
# 注册：https://www.pushplus.plus/  微信扫码 → 复制 token
PUSHPLUS_TOKEN=

# ============== RSS 数据服务 ==============
# china-finance-rss 服务地址（一般不用改）
RSS_BASE_URL=http://localhost:8053

# ============== 调度时间 ==============
# 每天几点抓取
SCHEDULED_TIME=08:30
# 每天几点推送到微信
PUSH_TIME=09:25

# ============== Web 服务 ==============
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=0
